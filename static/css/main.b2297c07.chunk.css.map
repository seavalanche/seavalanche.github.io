* {
  margin: 0;
  padding: 0;
  font-family: "Montserrat";
}

.page-border {
  max-width: 1000px;
  width: 100%;
  margin-left: auto;
  margin-right: auto;
}

/* Extra small devices (phones, 600px and down) */
@media only screen and (max-width: 600px) {
  .navbar {
    height: 80px;
  }
  .navbar-container {
    max-width: 90vw;
    padding-top: 28px;
    padding-left: 5px;
    padding-right: 5px;
  }
  .navbar-menu {
    padding-top: 24px;
    min-width: 350px;
    font-size: 18px;
    align-items: baseline;
  }
  .SeavaLogo {
    position: absolute;
    top: 15px;
    left: 15px;
  }
  .KofiLogo {
    display: flex;
    align-self: flex-end;
    width: 130px;
    top: 18px;
    position: absolute;
    right: 18px;
  }
  .Mainpageitem {
    height: 164px;
    margin: 4px;
  }
  .itemimg {
    height: 130px;
  }
  .itemtext {
    font-size: 10px;
  }
  .LowerText {
    max-width: 480px;
    flex-wrap: wrap;
    flex-direction: row;
    justify-content: space-around;
  }
  .LowerText div {
    width: 40vw;
    padding-bottom: 5px;
  }
  .Projects b {
    height: 70px;
    font-size: 16pt;
    padding-top: 18px;
    padding-bottom: 10px;
    max-width: 90vw;
    text-align: center;
  }
  .Projectcard {
    width: 90vw;
    padding-top: 18px;
    padding-bottom: 18px;
    padding-left: 5px;
    padding-right: 5px;
    flex-direction: column;
  }
  .ProjectitemL {
    width: 80vw;
  }
  .ProjectitemR {
    width: 80vw;
  }
  .ProjectimgL {
    width: min(450px, 90vw);
    padding-bottom: 10px;
  }
  .ProjectimgR {
    width: min(450px, 90vw);
    padding-top: 10px;
  }
  .Projectcard h1 {
    font-size: 14pt;
  }
  .Projectcard h2 {
    font-size: 12pt;
    padding-left: 6px;
  }
  .Projectcard p {
    font-size: 12pt;
    width: 80vw;
    padding-top: 8px;
    padding-left: 20px;
  }
  .Showcase b {
    font-size: 42px;
  }
  .Showcaselist {
    padding-top: 12px;
    padding-bottom: 12px;
    width: 90vw;
  }
  .Showcaseitem {
    padding-bottom: 20px;
  }
  .Showcaseitem b {
    font-size: 16px;
  }
  .Showcaseitem p {
    font-size: 56px;
  }
  .CommissionHeader {
    width: 90%;
  }
  .CommissionTitle b {
    font-size: 24pt;
    height: 40px;
    padding-top: 15px;
  }
  .CommissionTitle h1 {
    font-size: 14pt;
    height: 50px;
  }
  .Commissionitem {
    font-size: 8pt;
  }
  .comitemimgcon {
    width: 420px;
  }
  .comitemimg {
    height: 80px;
    max-width: 100px;
  }
  .comitemtext {
    padding-left: 16px;
    width: 180px;
  }
  .TotalCommission {
    padding-top: 24px;
    padding-bottom: 24px;
  }
  .TotalCommission b {
    font-size: 12pt;
  }
  .TotalCommission p {
    font-size: 36pt;
  }
  .AboutSeavapic {
    width: 90%;
  }
  .AboutVesneapic {
    width: 90%;
  }
}

