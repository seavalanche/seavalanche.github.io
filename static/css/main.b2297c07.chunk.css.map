.LowerPart {
  display: flex;
  width: 100%;
  justify-content: center;
  margin-left: auto;
  margin-right: auto;
  align-items: center;
  position: relative;
}

.VesneaFooter {
  width: 100%;
  height: 542px;
  object-fit: cover;
}

.LowerPart::after {
  content: "";
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-image: linear-gradient(
    to top,
    rgba(76, 43, 87, 0.5) 0%,
    transparent 40%
  );
  mix-blend-mode: multiply;
}

.LowerText {
  display: flex;
  position: absolute;
  padding: 11px;
  bottom: 0px;
  justify-content: center;
  text-align: center;
  color: white;
  z-index: 1;
  font-size: 11px;
}

.Footer {
  width: 100%;
  height: 50px;
  background: #4c2c57;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 3px;
}

.FooterLogo {
  display: flex;
  min-width: 200px;
  margin-left: auto;
  margin-right: auto;
  align-items: center;
  justify-content: center;
}

.FooterSeava {
  padding-right: 8px;
}

.FooterStar {
  margin-left: auto;
  margin-right: auto;
}

.FooterOshyarena {
  padding-left: 10px;
}

.LowerText b {
  font-size: 13px;
}

