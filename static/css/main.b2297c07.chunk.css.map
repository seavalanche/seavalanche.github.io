    height: 500px;
    width: initial;
  }
  .CommissionTitle b {
    font-size: 36pt;
    height: 60px;
    padding-top: 30px;
  }
  .CommissionTitle h1 {
    font-size: 18pt;
    height: 80px;
  }
  .Commissionitem {
    font-size: 12pt;
  }
  .comitemimgcon {
    width: 650px;
  }
  .comitemimg {
    height: 150px;
    max-width: initial;
  }
  .comitemtext {
    padding-left: 18px;
    width: 250px;
  }
  .TotalCommission {
    padding-top: 30px;
    padding-bottom: 30px;
  }
  .TotalCommission b {
    font-size: 14pt;
  }
  .TotalCommission p {
    font-size: 48pt;
  }
  .AboutSeavapic {
    height: 500px;
  }
  .AboutVesneapic {
    height: 500px;
  }
}

