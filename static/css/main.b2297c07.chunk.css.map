    margin-right: 25px;
  }
  .Projects b {
    height: 80px;
    font-size: 18pt;
    padding-top: 20px;
    padding-bottom: 12px;
    max-width: initial;
    text-align: initial;
  }
  .Projectcard {
    width: 890px;
    padding-top: 24px;
    padding-bottom: 24px;
    padding-left: 5px;
    padding-right: 5px;
