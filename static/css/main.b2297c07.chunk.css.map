    left: initial;
  }

  .KofiLogo {
    display: initial;
    align-self: initial;
    width: initial;
    top: initial;
    position: initial;
    right: initial;
  }

  .Mainpageitem {
    height: 240px;
    margin: 6px;
  }
  .itemimg {
    height: 200px;
  }
  .itemtext {
    font-size: 13px;
  }
  .LowerText {
    max-width: 480px;
  }
