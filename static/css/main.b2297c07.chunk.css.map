}

.CommissionHeader {
  display: flex;
  margin-left: auto;
  margin-right: auto;
  padding-top: 24px;
}

.CommissionTitle b {
  font-style: italic;
  font-weight: 100;
  display: flex;
  justify-content: center;
  align-items: center;
}

.CommissionTitle a {
  color: inherit;
  text-decoration: none;
}

.CommissionTitle h1 {
  font-weight: 700;
  display: flex;
  justify-content: center;
  align-items: center;
}

.Commissionlist {
  padding-bottom: 54px;
}

.Commissionitem {
  display: flex;
  justify-content: center;
  align-items: center;
  font-weight: 300;
  margin-left: auto;
  margin-right: auto;
}

.comitemimgcon {
  display: flex;
  justify-content: right;
}

.comitemimg {
  display: flex;
  object-fit: cover;
  justify-content: right;
}

.TotalCommission {
  background-color: #f3fafe;
  color: #645059;
  text-align: center;
  background-image: url("./Assets/Mainpage/Mainpagewall.jpg");
  background-position: 0 -200px;
  background-size: cover;
  background-attachment: fixed;
}

.TotalCommission b {
  font-weight: 600;
  font-style: italic;
}

.TotalCommission p {
  font-weight: 600;
  font-style: normal;
}

