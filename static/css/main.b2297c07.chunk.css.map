  }
  .ProjectitemL {
    width: 450px;
  }
  .ProjectitemR {
    width: 450px;
  }
  .ProjectimgL {
    width: initial;
    padding-bottom: initial;
  }
  .ProjectimgR {
    width: initial;
    padding-top: initial;
  }
  .Projectcard h1 {
    font-size: 14pt;
  }
  .Projectcard h2 {
    font-size: 12pt;
    padding-left: 6px;
  }
  .Projectcard p {
    font-size: 12pt;
    width: 350px;
    padding-top: 10px;
    padding-left: 30px;
  }
  .Showcase b {
    font-size: 48px;
  }
  .Showcaselist {
    padding-top: 24px;
    padding-bottom: 24px;
    width: 890px;
  }
  .Showcaseitem {
    padding-bottom: 24px;
  }
  .Showcaseitem b {
    font-size: 20px;
  }
  .Showcaseitem p {
    font-size: 64px;
  }
