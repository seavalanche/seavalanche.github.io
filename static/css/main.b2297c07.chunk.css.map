/* Navbar Styles starts here */
.navbar {
  width: 100%;
  background: #f3fafe;
  filter: drop-shadow(0px 4px 4px rgba(0, 0, 0, 0.25));
  position: sticky;
  top: 0;
  z-index: 1;
}

/* .SeavaLogo:hover * {
  fill: #f3fafe;
  stroke: #645059;
} */

.navbar-container {
  display: flex;
  justify-content: center;
  margin-left: auto;
  margin-right: auto;
  align-items: center;
}

.navbar-menu {
  --clr1: #645059;
  --clr2: #f3fafe;
  display: flex;
  color: var(--clr1);
  justify-content: center;
  align-items: center;
  margin-left: auto;
  margin-right: auto;
  font-weight: 300;
  --txtblur: 2px;
  --txtshdw: var(--clr2);
  text-shadow: 0 0 var(--txtblur) var(--txtshdw),
    0 0 var(--txtblur) var(--txtshdw), 0 0 var(--txtblur) var(--txtshdw),
    0 0 var(--txtblur) var(--txtshdw), 0 0 var(--txtblur) var(--txtshdw),
    0 0 var(--txtblur) var(--txtshdw), 0 0 var(--txtblur) var(--txtshdw),
    0 0 var(--txtblur) var(--txtshdw), 0 0 var(--txtblur) var(--txtshdw),
    0 0 var(--txtblur) var(--txtshdw), 0 0 var(--txtblur) var(--txtshdw);
}

.nbmenutext {
  margin-left: auto;
  margin-right: auto;
}

.nbmenutext a {
  color: inherit;
  text-decoration: none;
}
/* Navbar Styles end here */
